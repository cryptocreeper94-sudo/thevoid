# The Void - Environment Variables
# Copy this to .env and fill in your values

DATABASE_URL=
PORT=5000
APP_DOMAIN=intothevoid.app

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenAI (for AI chat, audio, image features)
OPENAI_API_KEY=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=THE VOID <noreply@dwsc.io>

# Trust Layer SSO
JWT_SECRET=

# TrustVault
TRUSTVAULT_API_KEY=

# Session
SESSION_SECRET=
